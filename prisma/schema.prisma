generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  image         String?
  name          String?
  xp            Int       @default(0)
  level         Int       @default(0)
  currency      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       String?

  password      String?



// Relation
  decks         Deck[]
  gameSessions  GameSession[]
  inventory     Inventory?
  purchases     Purchase[]
  accounts      Account[]
  sessions      Session[]
  conceptProgress ConceptProgress[]
}


model Deck {
  id String @id  @default(cuid())
  userId String
  title String
  sourceType SourceType
  rawText Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

flashCards FlashCard[]
  sessions GameSession[]
  Concept Concept[]
  @@index([userId])
}
model Concept{
  id String @id @default(cuid())
  deckId String
  concept String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  conceptProgress ConceptProgress[]
}

model ConceptProgress {
  id String @id @default(cuid())
  userId String
  conceptId String
  dueAt DateTime @default(now())
  fsrsState Int @default(0)
  stability Float?
  difficulty Float?
  learningSteps Int @default(0)
  elapsedDays Int @default(0)
  scheduleDays Int @default(0)
  reps Int @default(0)
  lapses Int @default(0)
  lastReviewedAt DateTime?

  user User @relation(fields:[userId], references: [id], onDelete: Cascade)
  concept Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  @@unique([userId, conceptId])
  @@index([userId, dueAt])

}


model Inventory {
  id String @id @default(cuid())
  userId String @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

inventoryItems InventoryItem[]
}

model InventoryItem{
  id String @id @default(cuid())
  inventoryId String
  keyItem String
  quantity Int  @default(0)
  updatedAt DateTime @updatedAt
  inventory Inventory @relation(fields: [inventoryId], references: [id] ,onDelete: Cascade)

@@unique([inventoryId, keyItem])
@@index([inventoryId])
}

model Purchase {
  id String @id @default(cuid())
  userId String
  cost Int
  sessionId String?
  itemKey String
  purchasedAt DateTime @default(now())


  session GameSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model FlashCard {
  id String @id @default(cuid())
  deckId String
  question String
  correctAnswer String
  gameSessionId String
  gameSession GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  @@index([deckId])
}

model GameSession {
  id String @id @default(cuid())
  userId String
  deckId String

  startedAt DateTime @default(now())
  endedAt DateTime?

  title String @default("New Session")

  score Int @default(0)
  xpEarned Int @default(0)
  currencyEarned Int @default(0)
  correctCount Int @default(0)
  incorrectCount Int @default(0)
  streak Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  flashCards FlashCard[]

  purchases Purchase[]

@@index([userId])
@@index([deckId])
}




// ENUM


enum SourceType {
  FILE
  TOPIC
}

// GITHUB/GOOGLE
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
