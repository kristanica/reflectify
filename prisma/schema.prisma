generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  image         String?
  name          String?
  xp            Int       @default(0)
  level         Int       @default(0)
  currency      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       String?

  password      String?

  decks         Deck[]
  gameSessions  GameSession[]
  inventory     Inventory?
  purchases     Purchase[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Deck {
  id String @id  @default(cuid())
  userId String
  title String
  sourceType SourceType
  rawText Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  cards Card[]
  sessions GameSession[]


  @@index([userId])
}


model Inventory {
  id String @id @default(cuid())
userId String @unique


user User @relation(fields: [userId], references: [id], onDelete: Cascade)

inventoryItems InventoryItem[]
}

model InventoryItem{
  id String @id @default(cuid())
  inventoryId String
  keyItem String
  quantity Int  @default(0)
  updatedAt DateTime @updatedAt
  inventory Inventory @relation(fields: [inventoryId], references: [id] ,onDelete: Cascade)

@@unique([inventoryId, keyItem])
@@index([inventoryId])
}

model Purchase {
  id String @id @default(cuid())
  userId String
  cost Int
  sessionId String?
  itemKey String
  purchasedAt DateTime @default(now())


  session GameSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SourceType {
  FILE
  TOPIC
}




model Card {
  id String @id @default(cuid())
  deckId String 
  questionType QuestionType
  options String[]
  answer String
  difficulty Int @default(1)


  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
@@index([deckId])
}

model GameSession {
  id String @id @default(cuid())
  userId String 
  deckId String
  livesStart Int @default(3)


  startedAt DateTime @default(now())
  endedAt DateTime?


  livesEnd Int @default(3)
  score Int
  xpEarned Int
  currencyEarned Int
  correctCount Int
  incorrectCount Int
  streak Int


  user User @relation(fields: [userId], references: [id])
  deck Deck @relation(fields: [deckId], references: [id])


  purchases Purchase[]

@@index([userId])
@@index([deckId])
}




enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_OR_FALSE
  IDENTIFICATION
  SCENARIO
}